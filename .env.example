# Copy this to ".env" and Compose will load it automatically.
#   cp .env.example .env
# Never commit the real .env (it's in .dockerignore / should be in .gitignore).

# Shared JWT secret. Auth signs tokens with it; the gateway verifies with it.
# In production this would be a long random value from a secrets manager.
SECRET_KEY=change-me-to-a-long-random-secret
